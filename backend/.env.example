# Etherlink Omni-DEX Arbitrage Agent — Environment Configuration

# Etherlink Mainnet RPC
RPC_URL=https://node.mainnet.etherlink.com

# Chain ID
CHAIN_ID=42793

# GeckoTerminal network identifier for Etherlink
GECKO_NETWORK_ID=etherlink

# Minimum profit margin (0.005 = 0.5%) above gas cost to trigger a trade
MIN_PROFIT_MARGIN=0.005

# Loop interval in milliseconds (900000 = 15 minutes)
LOOP_INTERVAL_MS=900000

# Maximum slippage tolerance (0.01 = 1%)
MAX_SLIPPAGE=0.01

# Log level (debug, info, warn, error)
LOG_LEVEL=info
