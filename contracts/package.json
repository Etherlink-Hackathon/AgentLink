{
  "name": "etherlink-dex-contracts",
  "version": "1.0.0",
  "description": "ERC-4626 Vault contracts for the Etherlink Arbitrage Agent",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:etherlink": "hardhat run scripts/deploy.ts --network etherlink",
    "test:flow:local": "hardhat run scripts/test_flow.ts --network localhost",
    "test:flow:etherlink": "hardhat run scripts/test_flow.ts --network etherlink"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0"
  }
}
